{
  "$defs": {
    "ColourTaskItem": {
      "additionalProperties": false,
      "description": "A 'listen and colour' task (YLE). The student paints a line-art scene; it is\nteacher-reviewed (never auto-scored), like writing. The colouring `key` is\nauthoring-only guidance and, like `rubric`, never reaches the student.",
      "properties": {
        "asset_id": {
          "description": "Line-art scene to colour (transparent background).",
          "title": "Asset Id",
          "type": "string"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "item_type": {
          "const": "colour_task",
          "default": "colour_task",
          "title": "Item Type",
          "type": "string"
        },
        "key": {
          "default": "",
          "description": "What to colour what \u2014 teacher review guidance (never served).",
          "title": "Key",
          "type": "string"
        },
        "palette": {
          "description": "Selectable brush colours offered to the student.",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Palette",
          "type": "array"
        },
        "prompt": {
          "title": "Prompt",
          "type": "string"
        }
      },
      "required": [
        "id",
        "prompt",
        "asset_id"
      ],
      "title": "ColourTaskItem",
      "type": "object"
    },
    "GapFillItem": {
      "additionalProperties": false,
      "properties": {
        "accepted": {
          "description": "Exact acceptable answers.",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Accepted",
          "type": "array"
        },
        "accepted_variants": {
          "description": "Cambridge 'acceptable misspellings'.",
          "items": {
            "type": "string"
          },
          "title": "Accepted Variants",
          "type": "array"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "item_type": {
          "const": "gap_fill",
          "default": "gap_fill",
          "title": "Item Type",
          "type": "string"
        },
        "prompt": {
          "title": "Prompt",
          "type": "string"
        }
      },
      "required": [
        "id",
        "prompt",
        "accepted"
      ],
      "title": "GapFillItem",
      "type": "object"
    },
    "ImageOption": {
      "additionalProperties": false,
      "properties": {
        "alt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Alt"
        },
        "asset_id": {
          "title": "Asset Id",
          "type": "string"
        },
        "key": {
          "description": "Canonical option key, e.g. 'A'. Authoring-only.",
          "title": "Key",
          "type": "string"
        },
        "kind": {
          "const": "image",
          "default": "image",
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "key",
        "asset_id"
      ],
      "title": "ImageOption",
      "type": "object"
    },
    "MatchingItem": {
      "additionalProperties": false,
      "properties": {
        "correct": {
          "description": "`key` of the correct option in the section pool.",
          "title": "Correct",
          "type": "string"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "item_type": {
          "const": "matching",
          "default": "matching",
          "title": "Item Type",
          "type": "string"
        },
        "prompt": {
          "title": "Prompt",
          "type": "string"
        }
      },
      "required": [
        "id",
        "prompt",
        "correct"
      ],
      "title": "MatchingItem",
      "type": "object"
    },
    "OpenWritingItem": {
      "additionalProperties": false,
      "properties": {
        "bullet_points": {
          "items": {
            "type": "string"
          },
          "title": "Bullet Points",
          "type": "array"
        },
        "grade_mode": {
          "default": "llm",
          "enum": [
            "llm",
            "manual"
          ],
          "title": "Grade Mode",
          "type": "string"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "item_type": {
          "const": "open_writing",
          "default": "open_writing",
          "title": "Item Type",
          "type": "string"
        },
        "prompt": {
          "title": "Prompt",
          "type": "string"
        },
        "rubric": {
          "description": "Grading guidance (authoring-only, never served).",
          "title": "Rubric",
          "type": "string"
        },
        "word_min": {
          "exclusiveMinimum": 0,
          "title": "Word Min",
          "type": "integer"
        }
      },
      "required": [
        "id",
        "prompt",
        "word_min",
        "rubric"
      ],
      "title": "OpenWritingItem",
      "type": "object"
    },
    "SingleChoiceItem": {
      "additionalProperties": false,
      "properties": {
        "correct": {
          "description": "Canonical `key` of the correct option.",
          "title": "Correct",
          "type": "string"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "image": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional picture shown with the prompt (e.g. a picture to label).",
          "title": "Image"
        },
        "item_type": {
          "const": "single_choice",
          "default": "single_choice",
          "title": "Item Type",
          "type": "string"
        },
        "options": {
          "items": {
            "discriminator": {
              "mapping": {
                "image": "#/$defs/ImageOption",
                "text": "#/$defs/TextOption"
              },
              "propertyName": "kind"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/TextOption"
              },
              {
                "$ref": "#/$defs/ImageOption"
              }
            ]
          },
          "minItems": 2,
          "title": "Options",
          "type": "array"
        },
        "prompt": {
          "title": "Prompt",
          "type": "string"
        }
      },
      "required": [
        "id",
        "prompt",
        "options",
        "correct"
      ],
      "title": "SingleChoiceItem",
      "type": "object"
    },
    "TextOption": {
      "additionalProperties": false,
      "properties": {
        "key": {
          "description": "Canonical option key, e.g. 'A'. Authoring-only.",
          "title": "Key",
          "type": "string"
        },
        "kind": {
          "const": "text",
          "default": "text",
          "title": "Kind",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "key",
        "text"
      ],
      "title": "TextOption",
      "type": "object"
    }
  },
  "discriminator": {
    "mapping": {
      "colour_task": "#/$defs/ColourTaskItem",
      "gap_fill": "#/$defs/GapFillItem",
      "matching": "#/$defs/MatchingItem",
      "open_writing": "#/$defs/OpenWritingItem",
      "single_choice": "#/$defs/SingleChoiceItem"
    },
    "propertyName": "item_type"
  },
  "oneOf": [
    {
      "$ref": "#/$defs/SingleChoiceItem"
    },
    {
      "$ref": "#/$defs/GapFillItem"
    },
    {
      "$ref": "#/$defs/MatchingItem"
    },
    {
      "$ref": "#/$defs/OpenWritingItem"
    },
    {
      "$ref": "#/$defs/ColourTaskItem"
    }
  ]
}
