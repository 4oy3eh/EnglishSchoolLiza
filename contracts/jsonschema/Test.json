{
  "$defs": {
    "AudioAssetStimulus": {
      "additionalProperties": false,
      "properties": {
        "asset_id": {
          "title": "Asset Id",
          "type": "string"
        },
        "images": {
          "description": "Optional context image asset_ids shown beside this stimulus.",
          "items": {
            "type": "string"
          },
          "title": "Images",
          "type": "array"
        },
        "kind": {
          "const": "audio_asset",
          "default": "audio_asset",
          "title": "Kind",
          "type": "string"
        },
        "locked": {
          "default": true,
          "description": "When true the main track cannot be paused, seeked, or replayed once started (leaving/answering does not stop it); the preview clip stays free.",
          "title": "Locked",
          "type": "boolean"
        },
        "look_through_seconds": {
          "default": 0,
          "minimum": 0,
          "title": "Look Through Seconds",
          "type": "integer"
        },
        "plays": {
          "default": 1,
          "description": "Replay limit for the main track. Default 1: Cambridge recordings already bake in the double play, so the online track is played once start-to-end.",
          "minimum": 1,
          "title": "Plays",
          "type": "integer"
        },
        "preview_asset_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional sound-check / instructions clip (the recording's opening explanation), played BEFORE the main track and freely replayable.",
          "title": "Preview Asset Id"
        }
      },
      "required": [
        "asset_id"
      ],
      "title": "AudioAssetStimulus",
      "type": "object"
    },
    "ColourTaskItem": {
      "additionalProperties": false,
      "description": "A 'listen and colour' task (YLE). The student paints a line-art scene; it is\nteacher-reviewed (never auto-scored), like writing. The colouring `key` is\nauthoring-only guidance and, like `rubric`, never reaches the student.",
      "properties": {
        "asset_id": {
          "description": "Line-art scene to colour (transparent background).",
          "title": "Asset Id",
          "type": "string"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "item_type": {
          "const": "colour_task",
          "default": "colour_task",
          "title": "Item Type",
          "type": "string"
        },
        "key": {
          "default": "",
          "description": "What to colour what \u2014 teacher review guidance (never served).",
          "title": "Key",
          "type": "string"
        },
        "palette": {
          "description": "Selectable brush colours offered to the student.",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Palette",
          "type": "array"
        },
        "prompt": {
          "title": "Prompt",
          "type": "string"
        }
      },
      "required": [
        "id",
        "prompt",
        "asset_id"
      ],
      "title": "ColourTaskItem",
      "type": "object"
    },
    "GapFillItem": {
      "additionalProperties": false,
      "properties": {
        "accepted": {
          "description": "Exact acceptable answers.",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Accepted",
          "type": "array"
        },
        "accepted_variants": {
          "description": "Cambridge 'acceptable misspellings'.",
          "items": {
            "type": "string"
          },
          "title": "Accepted Variants",
          "type": "array"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "item_type": {
          "const": "gap_fill",
          "default": "gap_fill",
          "title": "Item Type",
          "type": "string"
        },
        "prompt": {
          "title": "Prompt",
          "type": "string"
        }
      },
      "required": [
        "id",
        "prompt",
        "accepted"
      ],
      "title": "GapFillItem",
      "type": "object"
    },
    "GappedTextStimulus": {
      "additionalProperties": false,
      "properties": {
        "images": {
          "description": "Optional context image asset_ids shown beside this stimulus.",
          "items": {
            "type": "string"
          },
          "title": "Images",
          "type": "array"
        },
        "kind": {
          "const": "gapped_text",
          "default": "gapped_text",
          "title": "Kind",
          "type": "string"
        },
        "text": {
          "description": "Passage text with gap markers (PET Reading Part 4).",
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "text"
      ],
      "title": "GappedTextStimulus",
      "type": "object"
    },
    "ImageOption": {
      "additionalProperties": false,
      "properties": {
        "alt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Alt"
        },
        "asset_id": {
          "title": "Asset Id",
          "type": "string"
        },
        "key": {
          "description": "Canonical option key, e.g. 'A'. Authoring-only.",
          "title": "Key",
          "type": "string"
        },
        "kind": {
          "const": "image",
          "default": "image",
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "key",
        "asset_id"
      ],
      "title": "ImageOption",
      "type": "object"
    },
    "ImageSetStimulus": {
      "additionalProperties": false,
      "properties": {
        "asset_ids": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Asset Ids",
          "type": "array"
        },
        "kind": {
          "const": "image_set",
          "default": "image_set",
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "asset_ids"
      ],
      "title": "ImageSetStimulus",
      "type": "object"
    },
    "MatchingItem": {
      "additionalProperties": false,
      "properties": {
        "correct": {
          "description": "`key` of the correct option in the section pool.",
          "title": "Correct",
          "type": "string"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "item_type": {
          "const": "matching",
          "default": "matching",
          "title": "Item Type",
          "type": "string"
        },
        "prompt": {
          "title": "Prompt",
          "type": "string"
        }
      },
      "required": [
        "id",
        "prompt",
        "correct"
      ],
      "title": "MatchingItem",
      "type": "object"
    },
    "MatchingPoolStimulus": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "matching_pool",
          "default": "matching_pool",
          "title": "Kind",
          "type": "string"
        },
        "options": {
          "items": {
            "$ref": "#/$defs/PoolOption"
          },
          "minItems": 2,
          "title": "Options",
          "type": "array"
        },
        "text": {
          "default": "",
          "description": "Optional passage/intro shown above the A-H pool (e.g. a gapped text).",
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "options"
      ],
      "title": "MatchingPoolStimulus",
      "type": "object"
    },
    "OpenWritingItem": {
      "additionalProperties": false,
      "properties": {
        "bullet_points": {
          "items": {
            "type": "string"
          },
          "title": "Bullet Points",
          "type": "array"
        },
        "grade_mode": {
          "default": "llm",
          "enum": [
            "llm",
            "manual"
          ],
          "title": "Grade Mode",
          "type": "string"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "item_type": {
          "const": "open_writing",
          "default": "open_writing",
          "title": "Item Type",
          "type": "string"
        },
        "prompt": {
          "title": "Prompt",
          "type": "string"
        },
        "rubric": {
          "description": "Grading guidance (authoring-only, never served).",
          "title": "Rubric",
          "type": "string"
        },
        "word_min": {
          "exclusiveMinimum": 0,
          "title": "Word Min",
          "type": "integer"
        }
      },
      "required": [
        "id",
        "prompt",
        "word_min",
        "rubric"
      ],
      "title": "OpenWritingItem",
      "type": "object"
    },
    "PassageTextStimulus": {
      "additionalProperties": false,
      "properties": {
        "images": {
          "description": "Optional context image asset_ids shown beside this stimulus.",
          "items": {
            "type": "string"
          },
          "title": "Images",
          "type": "array"
        },
        "kind": {
          "const": "passage_text",
          "default": "passage_text",
          "title": "Kind",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "text"
      ],
      "title": "PassageTextStimulus",
      "type": "object"
    },
    "PoolOption": {
      "additionalProperties": false,
      "description": "One option in a section-level matching pool (A-H). No correctness here.",
      "properties": {
        "key": {
          "title": "Key",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "key",
        "text"
      ],
      "title": "PoolOption",
      "type": "object"
    },
    "Section": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "items": {
          "items": {
            "discriminator": {
              "mapping": {
                "colour_task": "#/$defs/ColourTaskItem",
                "gap_fill": "#/$defs/GapFillItem",
                "matching": "#/$defs/MatchingItem",
                "open_writing": "#/$defs/OpenWritingItem",
                "single_choice": "#/$defs/SingleChoiceItem"
              },
              "propertyName": "item_type"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/SingleChoiceItem"
              },
              {
                "$ref": "#/$defs/GapFillItem"
              },
              {
                "$ref": "#/$defs/MatchingItem"
              },
              {
                "$ref": "#/$defs/OpenWritingItem"
              },
              {
                "$ref": "#/$defs/ColourTaskItem"
              }
            ]
          },
          "minItems": 1,
          "title": "Items",
          "type": "array"
        },
        "skill": {
          "anyOf": [
            {
              "enum": [
                "reading",
                "listening",
                "writing"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Skill"
        },
        "stimulus": {
          "discriminator": {
            "mapping": {
              "audio_asset": "#/$defs/AudioAssetStimulus",
              "gapped_text": "#/$defs/GappedTextStimulus",
              "image_set": "#/$defs/ImageSetStimulus",
              "matching_pool": "#/$defs/MatchingPoolStimulus",
              "passage_text": "#/$defs/PassageTextStimulus"
            },
            "propertyName": "kind"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/PassageTextStimulus"
            },
            {
              "$ref": "#/$defs/AudioAssetStimulus"
            },
            {
              "$ref": "#/$defs/ImageSetStimulus"
            },
            {
              "$ref": "#/$defs/GappedTextStimulus"
            },
            {
              "$ref": "#/$defs/MatchingPoolStimulus"
            }
          ],
          "title": "Stimulus"
        },
        "title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Title"
        }
      },
      "required": [
        "id",
        "stimulus",
        "items"
      ],
      "title": "Section",
      "type": "object"
    },
    "SingleChoiceItem": {
      "additionalProperties": false,
      "properties": {
        "correct": {
          "description": "Canonical `key` of the correct option.",
          "title": "Correct",
          "type": "string"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "image": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional picture shown with the prompt (e.g. a picture to label).",
          "title": "Image"
        },
        "item_type": {
          "const": "single_choice",
          "default": "single_choice",
          "title": "Item Type",
          "type": "string"
        },
        "options": {
          "items": {
            "discriminator": {
              "mapping": {
                "image": "#/$defs/ImageOption",
                "text": "#/$defs/TextOption"
              },
              "propertyName": "kind"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/TextOption"
              },
              {
                "$ref": "#/$defs/ImageOption"
              }
            ]
          },
          "minItems": 2,
          "title": "Options",
          "type": "array"
        },
        "prompt": {
          "title": "Prompt",
          "type": "string"
        }
      },
      "required": [
        "id",
        "prompt",
        "options",
        "correct"
      ],
      "title": "SingleChoiceItem",
      "type": "object"
    },
    "TextOption": {
      "additionalProperties": false,
      "properties": {
        "key": {
          "description": "Canonical option key, e.g. 'A'. Authoring-only.",
          "title": "Key",
          "type": "string"
        },
        "kind": {
          "const": "text",
          "default": "text",
          "title": "Kind",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "key",
        "text"
      ],
      "title": "TextOption",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "duration_minutes": {
      "exclusiveMinimum": 0,
      "title": "Duration Minutes",
      "type": "integer"
    },
    "id": {
      "title": "Id",
      "type": "string"
    },
    "level": {
      "enum": [
        "A1_MOVERS",
        "A2_KEY",
        "B1_PRELIMINARY"
      ],
      "title": "Level",
      "type": "string"
    },
    "sections": {
      "items": {
        "$ref": "#/$defs/Section"
      },
      "minItems": 1,
      "title": "Sections",
      "type": "array"
    },
    "status": {
      "default": "draft",
      "enum": [
        "draft",
        "published"
      ],
      "title": "Status",
      "type": "string"
    },
    "title": {
      "title": "Title",
      "type": "string"
    }
  },
  "required": [
    "id",
    "title",
    "level",
    "duration_minutes",
    "sections"
  ],
  "title": "Test",
  "type": "object"
}
