{
  "$defs": {
    "AudioAssetStimulus": {
      "additionalProperties": false,
      "properties": {
        "asset_id": {
          "title": "Asset Id",
          "type": "string"
        },
        "images": {
          "description": "Optional context image asset_ids shown beside this stimulus.",
          "items": {
            "type": "string"
          },
          "title": "Images",
          "type": "array"
        },
        "kind": {
          "const": "audio_asset",
          "default": "audio_asset",
          "title": "Kind",
          "type": "string"
        },
        "locked": {
          "default": true,
          "description": "When true the main track cannot be paused, seeked, or replayed once started (leaving/answering does not stop it); the preview clip stays free.",
          "title": "Locked",
          "type": "boolean"
        },
        "look_through_seconds": {
          "default": 0,
          "minimum": 0,
          "title": "Look Through Seconds",
          "type": "integer"
        },
        "plays": {
          "default": 1,
          "description": "Replay limit for the main track. Default 1: Cambridge recordings already bake in the double play, so the online track is played once start-to-end.",
          "minimum": 1,
          "title": "Plays",
          "type": "integer"
        },
        "preview_asset_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional sound-check / instructions clip (the recording's opening explanation), played BEFORE the main track and freely replayable.",
          "title": "Preview Asset Id"
        }
      },
      "required": [
        "asset_id"
      ],
      "title": "AudioAssetStimulus",
      "type": "object"
    },
    "GappedTextStimulus": {
      "additionalProperties": false,
      "properties": {
        "images": {
          "description": "Optional context image asset_ids shown beside this stimulus.",
          "items": {
            "type": "string"
          },
          "title": "Images",
          "type": "array"
        },
        "kind": {
          "const": "gapped_text",
          "default": "gapped_text",
          "title": "Kind",
          "type": "string"
        },
        "text": {
          "description": "Passage text with gap markers (PET Reading Part 4).",
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "text"
      ],
      "title": "GappedTextStimulus",
      "type": "object"
    },
    "ImageSetStimulus": {
      "additionalProperties": false,
      "properties": {
        "asset_ids": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Asset Ids",
          "type": "array"
        },
        "kind": {
          "const": "image_set",
          "default": "image_set",
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "asset_ids"
      ],
      "title": "ImageSetStimulus",
      "type": "object"
    },
    "MatchingPoolStimulus": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "matching_pool",
          "default": "matching_pool",
          "title": "Kind",
          "type": "string"
        },
        "options": {
          "items": {
            "$ref": "#/$defs/PoolOption"
          },
          "minItems": 2,
          "title": "Options",
          "type": "array"
        },
        "text": {
          "default": "",
          "description": "Optional passage/intro shown above the A-H pool (e.g. a gapped text).",
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "options"
      ],
      "title": "MatchingPoolStimulus",
      "type": "object"
    },
    "PassageTextStimulus": {
      "additionalProperties": false,
      "properties": {
        "images": {
          "description": "Optional context image asset_ids shown beside this stimulus.",
          "items": {
            "type": "string"
          },
          "title": "Images",
          "type": "array"
        },
        "kind": {
          "const": "passage_text",
          "default": "passage_text",
          "title": "Kind",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "text"
      ],
      "title": "PassageTextStimulus",
      "type": "object"
    },
    "PoolOption": {
      "additionalProperties": false,
      "description": "One option in a section-level matching pool (A-H). No correctness here.",
      "properties": {
        "key": {
          "title": "Key",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "key",
        "text"
      ],
      "title": "PoolOption",
      "type": "object"
    }
  },
  "discriminator": {
    "mapping": {
      "audio_asset": "#/$defs/AudioAssetStimulus",
      "gapped_text": "#/$defs/GappedTextStimulus",
      "image_set": "#/$defs/ImageSetStimulus",
      "matching_pool": "#/$defs/MatchingPoolStimulus",
      "passage_text": "#/$defs/PassageTextStimulus"
    },
    "propertyName": "kind"
  },
  "oneOf": [
    {
      "$ref": "#/$defs/PassageTextStimulus"
    },
    {
      "$ref": "#/$defs/AudioAssetStimulus"
    },
    {
      "$ref": "#/$defs/ImageSetStimulus"
    },
    {
      "$ref": "#/$defs/GappedTextStimulus"
    },
    {
      "$ref": "#/$defs/MatchingPoolStimulus"
    }
  ]
}
