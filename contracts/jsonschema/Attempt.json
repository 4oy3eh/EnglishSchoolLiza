{
  "additionalProperties": false,
  "properties": {
    "audio_progress_seconds": {
      "default": 0,
      "description": "Furthest point (seconds) the student has reached in the listening track. Server-side + monotonic, so a refresh/new device resumes from here and can never replay the recording from the start.",
      "minimum": 0,
      "title": "Audio Progress Seconds",
      "type": "integer"
    },
    "deadline": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Server-authoritative hard deadline: min(start + duration, window close).",
      "title": "Deadline"
    },
    "id": {
      "title": "Id",
      "type": "string"
    },
    "roster_entry_id": {
      "title": "Roster Entry Id",
      "type": "string"
    },
    "seed": {
      "description": "Seed for reproducible pooling + option shuffle.",
      "title": "Seed",
      "type": "integer"
    },
    "started_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Started At"
    },
    "status": {
      "default": "not_started",
      "enum": [
        "not_started",
        "in_progress",
        "submitted",
        "expired"
      ],
      "title": "Status",
      "type": "string"
    },
    "submitted_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Submitted At"
    },
    "test_id": {
      "title": "Test Id",
      "type": "string"
    }
  },
  "required": [
    "id",
    "test_id",
    "roster_entry_id",
    "seed"
  ],
  "title": "Attempt",
  "type": "object"
}
